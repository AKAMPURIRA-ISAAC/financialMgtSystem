# Finance Pro 2.0 - Environment Configuration Template
# Copy this to .env and customize your settings

# === APP SETTINGS ===
DEBUG=False
APP_NAME=Finance Pro 2.0

# === DATABASE ===
DB_PATH=finance_pro_advanced.db

# === API CONFIGURATION ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# === ML/AI SETTINGS ===
ENABLE_ML_FEATURES=True
ANOMALY_SENSITIVITY=0.15
PREDICTION_CONFIDENCE_THRESHOLD=0.6

# === CURRENCY SETTINGS ===
DEFAULT_CURRENCY=UGX

# === EXCHANGE RATE API ===
# Get API key from https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_api_key_here
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# === PLAID BANK INTEGRATION ===
# Get credentials from https://plaid.com/
ENABLE_BANK_SYNC=False
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENVIRONMENT=sandbox

# === CLOUD SYNC ===
ENABLE_CLOUD_SYNC=False

# === UI SETTINGS ===
THEME=dark
LANGUAGE=en
WINDOW_WIDTH=400
WINDOW_HEIGHT=700

# === FEATURES ===
ENABLE_ANALYTICS=True
ENABLE_BUDGET_ALERTS=True
ENABLE_ANOMALY_ALERTS=True
BUDGET_ALERT_THRESHOLD=80

# === BACKUP ===
BACKUP_ENABLED=True
BACKUP_FREQUENCY=daily
BACKUP_PATH=./backups

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=finance_pro.log
